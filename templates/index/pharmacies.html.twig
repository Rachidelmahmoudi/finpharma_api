 {% block javascripts %}
    <script>
    function getInfoBox(data) {
        return new InfoBox({
            content:
            '<div class="marker_info">' +
                '<figure>' +
                '<a href="' + data.url_detail + '">' +
                    '<img src="' + data.map_image_url + '" alt="Image">' +
                '</a>' +
                '</figure>' +
                '<small>' + data.type + '</small>' +
                '<h3><a href="' + data.url_detail + '">' + data.name_point + '</a></h3>' +
                '<span>' + data.description_point + '</span>' +
                '<div class="marker_tools">' +

                '<form action="http://maps.google.com/maps" method="get" target="_blank" style="display:inline-block">' +
                    '<input name="saddr" value="' + data.get_directions_start_address + '" type="hidden">' +
                    '<input type="hidden" name="daddr" value="' +
                    data.location_latitude + ',' + data.location_longitude +
                    '">' +
                    '<button type="submit" class="btn_infobox_get_directions">Directions</button>' +
                '</form>' +

                '<a href="tel://' + data.phone + '" class="btn_infobox_phone">' +
                    data.phone +
                '</a>' +

                '</div>' +
            '</div>',

            disableAutoPan: false,
            maxWidth: 0,
            pixelOffset: new google.maps.Size(10, 105),
            closeBoxMargin: "",
            closeBoxURL: "img/close_infobox.png",
            isHidden: false,
            alignBottom: true,
            pane: "floatPane",
