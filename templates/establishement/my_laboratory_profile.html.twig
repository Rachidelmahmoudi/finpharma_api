									<!-- End review-box -->
									
								</div>
								<!-- End review-container -->
								<hr>
								<div class="text-end"><a href="submit-review.html" class="btn_1 add_bottom_15">Submit review</a></div>
							</div>
							<!-- /tab_3 -->
						</div>
						<!-- /tab-content -->
					</div>
					<!-- /tabs_styled -->
				</div>
				<!-- /col -->
			</div>
			<!-- /row -->
		</div>
		<!-- /container -->
    </div>
{% endblock %}